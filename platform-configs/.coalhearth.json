{
  // Advisory budget-guardrail thresholds (char-heuristic best-effort, NOT a
  // precise or guaranteed token/turn count — see lib/budget-tracker.js header).
  "budgets": {
    "maxTurns": 30,
    "maxTokens": 2000000,
    "warningTurnThreshold": 5,
    "warningTokenPercentage": 0.15
  },
  // Handoff journal (the recovery core — this is the part that matters).
  "journal": {
    "outputDirectory": ".claude/coalhearth",
    "atomicityRetries": 3
  },
  // Resume-on-boot behavior.
  "recovery": {
    "autoInjectPrompt": true,
    "stashUnsavedChanges": true
  },
  // Self-update (orthogonal to the journal/resume hooks — its own off-switch).
  // The SessionStart hook only SCHEDULES a check via a throttled local stamp (no
  // network); the AGENT verifies the latest tag and offers `claude plugin update
  // coalhearth@coalhearth` (/coalhearth:update), consent-gated. updateMode: ask =
  // on the first due session, ask once how to handle updates; auto = standing
  // consent to check + offer; remind = a free reminder, you run it; off = silent.
  // updateCheckDays: days between checks (1-365; out-of-range clamps to 14 on read).
  "update": {
    "updateMode": "ask",
    "updateCheckDays": 14
  }
}
