// CoalHearth — Antigravity (AG 2.0) hooks template.
//
// AG shipped a real IDE hook engine (hooks.json, confirmed 2026-07-12). This wires
// CoalHearth's two Phoenix-13 hooks onto AG's events. Copy this file to ONE of:
//   - project:  <workspace>/.agents/hooks.json
//   - global:   ~/.gemini/config/hooks.json      (canonical; NOT the older
//                                                  ~/.gemini/antigravity-cli/ path)
// then replace __COALHEARTH_DIR__ with the directory holding CoalHearth's bin/ + lib/
// (a global file-copy install puts them at ~/.gemini/config/skills/coalhearth).
//
// If AG's parser rejects // comments, strip these comment lines — the object below is
// otherwise strict JSON. (This template mirrors the repo's platform-configs/*.json idiom.)
//
// Event mapping (AG has NO one-shot SessionStart — it never fires in the AG CLI/IDE):
//   PreInvocation  -> ag-pre-invocation.js : warm-resume, injected once per session
//                     (a per-session tmp marker guards against re-injecting every turn).
//   PostToolUse    -> ag-post-tool-use.js  : the handoff journal step, every tool call.
// Both fail-silent, zero-dep, no network, no child process; the only output is the
// sanctioned additionalContext JSON.
{
  "coalhearth": {
    "PreInvocation": [
      { "type": "command", "command": "node \"__COALHEARTH_DIR__/bin/ag-pre-invocation.js\" PreInvocation", "timeout": 30 }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "node \"__COALHEARTH_DIR__/bin/ag-post-tool-use.js\" PostToolUse", "timeout": 30 }
        ]
      }
    ]
  }
}
